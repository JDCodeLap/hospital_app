# 이 파일을 복사해 ".env"로 만들고 실제 값을 채우세요. (.env는 git에 올리지 않음)
# DB 연결 주소: postgresql+psycopg://사용자:비밀번호@호스트:포트/DB이름
DATABASE_URL=postgresql+psycopg://postgres:<비밀번호>@localhost:5432/hospital
# 화면(프론트엔드) 주소 — 여기서 오는 요청만 허용(CORS). 여러 개면 콤마로 구분
CORS_ORIGINS=http://localhost:3000
# 로그인 토큰 서명용 비밀키 — python -c "import secrets; print(secrets.token_hex(32))" 로 생성
JWT_SECRET_KEY=<랜덤_시크릿_생성해서_넣기>
# 토큰 유효시간(분). 기본 480분(8시간)
ACCESS_TOKEN_EXPIRE_MINUTES=480
